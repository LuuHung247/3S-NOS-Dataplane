# Zero Trust Lab — Suricata Detection Rules
# Zones: WEB=10.1.100.0/24  DB=10.1.200.0/24  APP=10.2.100.0/24  MGT=10.2.50.0/24

# ─── CATEGORY 1: Policy Violations (Critical) ──────────────────────────────────
# tc mirred capture is asymmetric (one direction only) → flow:to_server unreliable.
# Use flags:S (SYN-only) to fire on connection initiation; src_port=any, dst_port=service.
alert tcp 10.1.100.0/24 any -> 10.1.200.0/24 [5432,3306,1433,27017] (msg:"[ZT-VIOLATION] WEB direct to DB - microsegmentation bypass"; flags:S; classtype:policy-violation; priority:1; sid:9000001; rev:3;)
alert tcp 10.1.200.0/24 any -> ![10.1.100.0/24,10.1.200.0/24,10.2.100.0/24,10.2.50.0/24] any (msg:"[ZT-VIOLATION] DB initiating outbound connection"; flags:S; classtype:policy-violation; priority:1; sid:9000002; rev:4;)

# ─── CATEGORY 2: Lateral Movement ──────────────────────────────────────────────
# flags:S → only on SYN initiation; suppresses return-traffic FPs from shopper/scrape.
alert tcp 10.2.100.0/24 any -> 10.1.100.0/24 [80,443,22] (msg:"[ZT-ALERT] APP reverse call to WEB - lateral movement"; flags:S; classtype:policy-violation; priority:2; sid:9000003; rev:3;)
alert tcp 10.1.100.0/24 any -> 10.2.50.0/24 [22,3389] (msg:"[ZT-ALERT] WEB to MGT - unauthorized access"; flags:S; classtype:policy-violation; priority:2; sid:9000004; rev:3;)
alert tcp 10.2.100.0/24 any -> 10.2.50.0/24 [22,3389] (msg:"[ZT-ALERT] APP to MGT - unauthorized access"; flags:S; classtype:policy-violation; priority:2; sid:9000005; rev:3;)

# ─── CATEGORY 3: Reconnaissance ────────────────────────────────────────────────
alert icmp any any -> any any (msg:"[ZT-INFO] ICMP ping sweep detected"; itype:8; threshold:type both,track by_src,count 3,seconds 10; classtype:network-scan; priority:3; sid:9000010; rev:1;)
alert tcp [10.1.0.0/16,10.2.0.0/16] any -> [10.1.0.0/16,10.2.0.0/16] ![22,5432,8080] (msg:"[ZT-INFO] Possible port scan"; flags:S; threshold:type both,track by_src,count 15,seconds 10; classtype:network-scan; priority:3; sid:9000011; rev:2;)

# ─── CATEGORY 4: Audit Logging ─────────────────────────────────────────────────
alert ip 10.2.50.0/24 any -> any any (msg:"[ZT-AUDIT] Management zone access"; threshold:type limit,track by_src,count 1,seconds 60; classtype:policy-violation; priority:4; sid:9000020; rev:1;)

# ═══════════════════════════════════════════════════════════════════════════════
# YATESBURY BENCHMARK SIDs (NetVigil NSDI'24, Table 3)
# Signal-only — describe what was observed, never prescribe action.
# Agent reads KG `sids.md` + `threat-patterns.md` to reason action.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── CATEGORY 5: Reconnaissance — Scanning (Yatesbury) ─────────────────────────
# Vertical port scan — single src probing many ports on one dst.
alert tcp [10.1.0.0/16,10.2.0.0/16] any -> [10.1.0.0/16,10.2.0.0/16] ![22,5432,8080] (msg:"[ZT-RECON] Vertical port scan — many ports same destination"; flags:S; threshold:type both,track by_src,count 20,seconds 30; classtype:network-scan; priority:3; sid:9000040; rev:2;)

# Distributed TCP port scan — multiple srcs probing key service ports (per-src signal; agent correlates the multi-src pattern).
alert tcp [10.1.0.0/16,10.2.0.0/16] any -> [10.1.0.0/16,10.2.0.0/16] [23,80,443,3389,3306,1433,8443] (msg:"[ZT-RECON] TCP probe on key service ports"; flags:S; threshold:type both,track by_src,count 5,seconds 60; classtype:network-scan; priority:3; sid:9000041; rev:2;)

# Distributed UDP port scan — UDP variant.
alert udp [10.1.0.0/16,10.2.0.0/16] any -> [10.1.0.0/16,10.2.0.0/16] any (msg:"[ZT-RECON] UDP probe on many ports"; threshold:type both,track by_src,count 15,seconds 60; classtype:network-scan; priority:3; sid:9000042; rev:1;)

# ─── CATEGORY 6: Flooding (Yatesbury) ──────────────────────────────────────────
# SYN flood DoS — 1 src, sustained high rate to one dst (SYN without ACK).
alert tcp any any -> [10.1.0.0/16,10.2.0.0/16] any (msg:"[ZT-FLOOD] TCP SYN flood — sustained high rate from single source"; flags:S; threshold:type both,track by_src,count 200,seconds 10; classtype:attempted-dos; priority:2; sid:9000043; rev:1;)

# SYN flood DDoS — per-src contribution signal; agent aggregates per-dst across srcs.
alert tcp any any -> [10.1.0.0/16,10.2.0.0/16] any (msg:"[ZT-FLOOD] TCP SYN contribution from source"; flags:S; threshold:type both,track by_both,count 50,seconds 10; classtype:attempted-dos; priority:2; sid:9000044; rev:1;)

# UDP DDoS — UDP packet flood to one dst (track by_dst for aggregation across srcs).
alert udp any any -> [10.1.0.0/16,10.2.0.0/16] any (msg:"[ZT-FLOOD] UDP packet flood — high rate to destination"; threshold:type both,track by_dst,count 500,seconds 10; classtype:attempted-dos; priority:2; sid:9000045; rev:1;)

# ─── CATEGORY 7: Command & Control / Tunneling (Yatesbury) ─────────────────────
# C&C beacon — low-and-slow periodic small outbound to fixed external dst.
alert tcp [10.1.0.0/16,10.2.0.0/16] any -> ![10.1.0.0/16,10.2.0.0/16] any (msg:"[ZT-BEACON] Periodic small outbound — possible C2 heartbeat"; flags:S; dsize:<200; threshold:type both,track by_src,count 3,seconds 90; classtype:trojan-activity; priority:2; sid:9000046; rev:2;)

# DNS amplification — UDP response from port 53 with abnormally large payload to one dst.
alert udp any 53 -> [10.1.0.0/16,10.2.0.0/16] any (msg:"[ZT-AMP] DNS response with abnormally large payload"; dsize:>1000; threshold:type both,track by_dst,count 5,seconds 30; classtype:bad-unknown; priority:2; sid:9000047; rev:1;)

# ─── CATEGORY 8: Application-layer — DB content (Yatesbury) ────────────────────
# SQL injection — UNION SELECT.
alert tcp any any -> 10.1.200.0/24 [5432,3306,1433] (msg:"[ZT-CONTENT] SQL syntax — UNION SELECT in DB stream"; content:"UNION SELECT"; nocase; classtype:web-application-attack; priority:1; sid:9000048; rev:1;)

# SQL injection — OR 1=1 tautology.
alert tcp any any -> 10.1.200.0/24 [5432,3306,1433] (msg:"[ZT-CONTENT] SQL syntax — tautology condition in DB stream"; content:"OR 1=1"; nocase; classtype:web-application-attack; priority:1; sid:9000049; rev:1;)

# Destructive SQL statement — DROP/TRUNCATE/DELETE.
alert tcp any any -> 10.1.200.0/24 [5432,3306,1433] (msg:"[ZT-CONTENT] Destructive SQL statement in DB stream"; pcre:"/\b(DROP\s+TABLE|TRUNCATE|DELETE\s+FROM)\b/i"; classtype:web-application-attack; priority:1; sid:9000050; rev:1;)

# Unauthorized DB access — TCP to DB ports from any zone other than APP or DB itself.
alert tcp ![10.2.100.0/24,10.1.200.0/24] any -> 10.1.200.0/24 [5432,3306,1433,27017] (msg:"[ZT-VIOLATION] DB connection from non-APP zone"; flags:S; classtype:policy-violation; priority:1; sid:9000051; rev:1;)

# ─── CATEGORY 9: Multi-stage — Exploit recon (Yatesbury Infection Monkey) ──────
# Probe on commonly-exploited service ports (RDP, SMB, telnet, etc.).
# Per-source threshold; agent correlates with category-5 SIDs to detect monkey chain.
alert tcp [10.1.0.0/16,10.2.0.0/16] any -> [10.1.0.0/16,10.2.0.0/16] [23,135,139,445,3389,8443] (msg:"[ZT-RECON] Probe on commonly-exploited service port"; flags:S; threshold:type both,track by_src,count 10,seconds 60; classtype:attempted-recon; priority:3; sid:9000052; rev:2;)
